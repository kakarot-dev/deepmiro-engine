{
  "name": "deepmiro",
  "description": "DeepMiro swarm prediction engine. Run multi-agent social media simulations to predict how communities react to events, policies, and announcements.",
  "version": "0.1.0",
  "author": {
    "name": "kakarot-dev",
    "url": "https://deepmiro.org"
  },
  "homepage": "https://github.com/kakarot-dev/deepmiro",
  "license": "AGPL-3.0",
  "skills": ["./skills/predict"],
  "mcpServers": {
    "deepmiro": {
      "command": "npx",
      "args": ["-y", "deepmiro-mcp"],
      "env": {
        "DEEPMIRO_API_KEY": "${DEEPMIRO_API_KEY}"
      }
    }
  }
}
