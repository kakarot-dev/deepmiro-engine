# MiroFish MCP Server Configuration
# Copy to .env and fill in values: cp .env.example .env

# MiroFish backend URL
MIROFISH_URL=http://localhost:5001

# LLM API key (Fireworks AI recommended)
LLM_API_KEY=your_fireworks_api_key

# Transport: "stdio" for Claude Code, "http" for Claude Desktop / remote
TRANSPORT=stdio

# HTTP port (only used when TRANSPORT=http)
HTTP_PORT=3001

# Optional: API key for hosted mode (leave empty for self-hosted)
# MCP_API_KEY=your_mcp_api_key

# Request timeout for MiroFish backend calls (ms)
REQUEST_TIMEOUT_MS=120000

# Max retries for transient failures
MAX_RETRIES=3
