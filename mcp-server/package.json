{
  "name": "deepmiro-mcp",
  "version": "0.2.5",
  "description": "MCP server for DeepMiro — simulate hundreds of AI agents to predict outcomes from any document",
  "license": "AGPL-3.0-only",
  "type": "module",
  "mcpName": "io.github.kakarot-dev/deepmiro",
  "bin": {
    "deepmiro-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:stdio": "TRANSPORT=stdio node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agents",
    "swarm-intelligence",
    "prediction",
    "deepmiro",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kakarot-dev/deepmiro.git",
    "directory": "mcp-server"
  },
  "homepage": "https://deepmiro.org",
  "author": "Joel Libni <joel@deepmiro.org> (https://github.com/kakarot-dev)",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.7.0",
    "express": "^5.2.0",
    "form-data": "^4.0.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
